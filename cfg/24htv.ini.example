; ============================================
; Конфигурация SDK 24часаТВ
; ============================================
; Скопируйте этот файл и переименуйте в 24htv.ini
; Заполните значения для вашего провайдера
;
; Поддерживаются ENV-переменные: token = "${TWENTYFOURTV_TOKEN}"

[api]
; Токен из панели провайдера 24ТВ (обязательный)
token = "${TWENTYFOURTV_TOKEN}"

; Base URL API (по умолчанию: https://provapi.24h.tv/v2)
base_url = "https://provapi.24h.tv/v2"

; Таймаут запроса, сек (по умолчанию: 10)
timeout = 10

; Таймаут соединения, сек (по умолчанию: 5)
connect_timeout = 5

; Макс. количество повторов при 429/5xx (по умолчанию: 2)
max_retries = 2

; Circuit Breaker: порог ошибок до размыкания (по умолчанию: 5)
; circuit_breaker_threshold = 5

; Circuit Breaker: пауза после размыкания, сек (по умолчанию: 30)
; circuit_breaker_cooldown = 30

[provider]
; ID провайдера на платформе 24ТВ
id = ""

[callback]
; HMAC-секрет для верификации подписи входящих callback-запросов (опционально)
; Если не задан — проверка подписи отключена
; secret = ""
