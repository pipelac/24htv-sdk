{
    "name": "twentyfourtv/sdk",
    "description": "PHP SDK для интеграции с платформой 24часаТВ",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=5.6",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.50",
        "phpunit/phpunit": "^5.7.27 || ^6.5.14 || ^7.5.20 || ^8.5.21 || ^9.6 || ^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "TwentyFourTv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwentyFourTv\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist --colors=always",
        "test-coverage": "vendor/bin/phpunit --configuration phpunit.xml.dist --colors=always --coverage-clover build/coverage.xml",
        "analyse": "vendor/bin/phpstan analyse --configuration phpstan.neon --no-progress",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    }
}
