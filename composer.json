{
    "name": "twentyfourtv/sdk",
    "description": "PHP SDK для интеграции с платформой 24часаТВ",
    "type": "library",
    "license": "MIT",
    "keywords": ["24tv", "iptv", "sdk", "api", "ott"],
    "homepage": "https://github.com/twentyfourtv/sdk",
    "support": {
        "issues": "https://github.com/twentyfourtv/sdk/issues",
        "source": "https://github.com/twentyfourtv/sdk"
    },
    "require": {
        "php": ">=5.6",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "TwentyFourTv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwentyFourTv\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit --display-warnings",
        "test-coverage": "phpunit --coverage-text --coverage-clover=coverage.xml",
        "analyse": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "security": "@composer audit"
    }
}
